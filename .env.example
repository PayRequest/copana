# Copana Environment Variables
# Copy this to .env and fill in your keys.
# None of these are required for basic usage — only for automations.

# AI Provider (for automation scripts, not for Claude Code itself)
ANTHROPIC_API_KEY=
AI_MODEL=claude-haiku-4-5-20251001

# Telegram Bot (for mobile notifications)
# Create a bot via @BotFather on Telegram
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=

# Notification service (alternative to Telegram)
# Uses ntfy.sh — free, no account needed
NTFY_TOPIC=

# News feeds (comma-separated RSS URLs)
# Override default feeds for news briefing
NEWS_FEEDS=
